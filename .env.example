# PaperSynth Agent — Environment Configuration
# Copy this file to .env and fill in your API keys

# DeepSeek API key (required for hypothesis generation)
# Get one at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=*** API key (optional, for higher rate limits)
# Get one at: https://www.semanticscholar.org/product/api#api-key-form
S2_API_KEY=*** Usage:
#   papersynth "your research query"
#   papersynth "topic" -n 100 -h 5
#   papersynth "topic" --no-hypotheses -v
